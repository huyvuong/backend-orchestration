/*
 * SLURM configuration profile for Nextflow
 */

process {
    executor = 'slurm'
    queue = 'compute' // Default partition
    
    // Default resources
    cpus = 1
    memory = '4 GB'
    time = '4h'
    
    // Handle transient HPC errors
    errorStrategy = { task.exitStatus in [1, 255] ? 'retry' : 'finish' }
    maxRetries = 3

    // Process-specific resource allocations mapped to SLURM
    withLabel: 'process_high' {
        queue = 'highmem'
        cpus = 32
        memory = '256 GB'
        time = '24h'
    }
    
    // GPU queue example
    withLabel: 'gpu_process' {
        queue = 'gpu'
        clusterOptions = '--gres=gpu:v100:1'
        cpus = 4
        memory = '32 GB'
    }
}

executor {
    name = 'slurm'
    queueSize = 100 // Cap concurrent submissions to avoid overwhelming the head node
    submitRateLimit = '10 sec' 
}
