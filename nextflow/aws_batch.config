/*
 * AWS Batch configuration profile for Nextflow
 * Includes stub for DRAGEN FPGA (f1) instances.
 */

aws {
    region = 'us-west-2'
    batch {
        cliPath = '/home/ec2-user/miniconda/bin/aws'
        maxTransferAttempts = 3
        delayBetweenAttempts = '10 sec'
    }
}

process {
    executor = 'awsbatch'
    queue = 'nextflow-queue-prod'
    
    // Default resources
    cpus = 2
    memory = '4 GB'
    
    errorStrategy = { task.exitStatus in [143,137,104,134,139] ? 'retry' : 'finish' }
    maxRetries = 3
    maxErrors = '-1'

    // Process-specific resource allocations
    withLabel: 'process_high' {
        cpus = 16
        memory = '64 GB'
    }
    
    // DRAGEN specifically needs FPGA instances (f1.2xlarge or f1.16xlarge)
    withLabel: 'dragen' {
        queue = 'dragen-fpga-queue-prod' // Assuming a separate queue for f1 instances
        cpus = 8
        memory = '120 GB'
        container = 'illumina/dragen:4.0.3'
    }
}
